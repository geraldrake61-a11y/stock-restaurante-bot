# Copia este archivo como .env y rellena los valores reales

# Token del bot (te lo da @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=xxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID del Google Sheet (está en la URL del sheet)
GOOGLE_SHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Credenciales de Google Service Account (todo el JSON en una línea)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
